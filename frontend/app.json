{
  "expo": {
    "name": "Safinity",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Icons/app_logo.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": ["frontend", "com.safinityapp.frontend"],
    "owner": "beatriz-castros-organization",
    "platforms": ["ios", "android", "web"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safinityapp.frontend",
      "infoPlist": {
        "CFBundleDisplayName": "Safinity",
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Safinity uses your location to show your position on the event map."
      }
    },
    "android": {
      "package": "com.safinityapp.frontend",
      "adaptiveIcon": {
        "foregroundImage": "./assets/Icons/app_logo.png",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-camera",
      "expo-location",
      "expo-secure-store",
      "@clerk/expo"
    ],
    "updates": {
      "url": "https://u.expo.dev/c6d74fda-161d-47df-afad-75b5aa15930c"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "c6d74fda-161d-47df-afad-75b5aa15930c"
      }
    }
  }
}
